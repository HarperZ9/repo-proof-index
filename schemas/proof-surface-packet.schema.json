{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HarperZ9/repo-proof-index/schemas/proof-surface-packet.schema.json",
  "title": "Proof Surface Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proof_surface_version",
    "packet_id",
    "surface",
    "status",
    "claims",
    "checks",
    "action_items"
  ],
  "properties": {
    "proof_surface_version": {
      "const": "0.1"
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "surface": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "needs-polish",
        "blocked",
        "unknown"
      ]
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim",
          "evidence"
        ],
        "properties": {
          "claim": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "tool",
          "status",
          "summary"
        ],
        "properties": {
          "tool": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "warn",
              "fail",
              "unknown"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "action_items": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
